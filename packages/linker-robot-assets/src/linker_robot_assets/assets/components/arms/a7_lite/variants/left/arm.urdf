<?xml version="1.0" encoding="utf-8"?>
<!-- Joint kinematics (axes, limits, joint origins, effort/velocity)
     come from the vendor's per-side a7_lite_left URDF — the URDF the
     real robot/recorder uses. The previously committed component
     was derived from the combined LZARMzongzhuang.urdf, which had
     different sign conventions on L1/L2/L4 (axes flipped, limits
     negated/swapped) plus 12 mm errors on L3/L4 origin Z. Replay was
     getting clamped because of those.

     Inertials and mount-pad offsets (in a7_lite_torso) keep the
     LZARMzongzhuang values: the per-side URDFs assume a different
     base_link STL than the one our torso ships, so the truth's
     (0, 0.1435, 0) shoulder offset doesn't apply here.

     This component re-roots at a zero-mass virtual link L_arm_root so
     the recipe's fixed mount joint can live above the first revolute
     L1_Joint. Source's base_link → L1_Joint origin is absorbed into
     the a7_lite_torso arm_left_mount pad. Source L3 velocity=137.68
     looks like a typo (R3 has 37.68); copied verbatim. -->
<robot name="a7_lite_left">

  <link name="L_arm_root" />

  <link name="L1_Link">
    <inertial>
      <origin xyz="0.0045974 0.067978 0.00066635" rpy="0 0 0" />
      <mass value="1.1899" />
      <inertia
        ixx="0.0016082" ixy="3.5266E-06" ixz="2.0532E-07"
        iyy="0.00086283" iyz="6.5642E-06"
        izz="0.00092662" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/L1_Link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.75294 0.75294 0.75294 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/L1_Link.STL" />
      </geometry>
    </collision>
  </link>
  <joint name="L1_Joint" type="revolute">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="L_arm_root" />
    <child link="L1_Link" />
    <axis xyz="0 -1 0" />
    <limit lower="-2.18" upper="3.75" effort="60" velocity="18.84" />
  </joint>

  <link name="L2_Link">
    <inertial>
      <origin xyz="-0.030894 9.2644E-05 -0.099437" rpy="0 0 0" />
      <mass value="1.0659" />
      <inertia
        ixx="0.001451" ixy="3.1371E-06" ixz="-1.519E-06"
        iyy="0.0012495" iyz="-1.1542E-05"
        izz="0.0010752" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/L2_Link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.75294 0.75294 0.75294 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/L2_Link.STL" />
      </geometry>
    </collision>
  </link>
  <joint name="L2_Joint" type="revolute">
    <origin xyz="0.03125 0.0715 0" rpy="0 0 0" />
    <parent link="L1_Link" />
    <child link="L2_Link" />
    <axis xyz="-1 0 0" />
    <limit lower="-3.33" upper="0.19" effort="60" velocity="18.84" />
  </joint>

  <link name="L3_Link">
    <inertial>
      <origin xyz="-5.9577E-05 0.001318 -0.078466" rpy="0 0 0" />
      <mass value="1.2763" />
      <inertia
        ixx="0.00078242" ixy="-2.9327E-07" ixz="7.1339E-06"
        iyy="0.0010444" iyz="-2.978E-07"
        izz="0.00063166" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/L3_Link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.75294 0.75294 0.75294 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/L3_Link.STL" />
      </geometry>
    </collision>
  </link>
  <joint name="L3_Joint" type="revolute">
    <origin xyz="-0.03125 0 -0.147" rpy="0 0 0" />
    <parent link="L2_Link" />
    <child link="L3_Link" />
    <axis xyz="0 0 1" />
    <limit lower="-2.26" upper="2.26" effort="17" velocity="137.68" />
  </joint>

  <link name="L4_Link">
    <inertial>
      <origin xyz="1.6127E-05 -0.027094 -0.086199" rpy="0 0 0" />
      <mass value="0.66812" />
      <inertia
        ixx="0.00039892" ixy="5.379E-08" ixz="1.7668E-06"
        iyy="0.00038456" iyz="1.0506E-06"
        izz="0.00041366" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/L4_Link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.75294 0.75294 0.75294 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/L4_Link.STL" />
      </geometry>
    </collision>
  </link>
  <joint name="L4_Joint" type="revolute">
    <origin xyz="0 0.027 -0.126" rpy="0 0 0" />
    <parent link="L3_Link" />
    <child link="L4_Link" />
    <axis xyz="0 -1 0" />
    <limit lower="-0.78" upper="1.74" effort="36" velocity="10.47" />
  </joint>

  <link name="L5_Link">
    <inertial>
      <origin xyz="-0.00012977 0.0029474 -0.03886" rpy="0 0 0" />
      <mass value="0.4439" />
      <inertia
        ixx="0.00015511" ixy="-4.6133E-07" ixz="-2.6472E-06"
        iyy="0.00022136" iyz="-1.0454E-07"
        izz="0.00013737" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/L5_Link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.75294 0.75294 0.75294 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/L5_Link.STL" />
      </geometry>
    </collision>
  </link>
  <joint name="L5_Joint" type="revolute">
    <origin xyz="0 -0.027 -0.136" rpy="0 0 0" />
    <parent link="L4_Link" />
    <child link="L5_Link" />
    <axis xyz="0 0 1" />
    <limit lower="-2.96" upper="2.96" effort="14" velocity="27.21" />
  </joint>

  <link name="L6_Link">
    <inertial>
      <origin xyz="0.0023746 -0.027691 -0.063927" rpy="0 0 0" />
      <mass value="0.5193" />
      <inertia
        ixx="0.00031746" ixy="-6.3455E-07" ixz="4.1005E-07"
        iyy="0.00024364" iyz="2.8635E-06"
        izz="0.00015858" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/L6_Link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.75294 0.75294 0.75294 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/L6_Link.STL" />
      </geometry>
    </collision>
  </link>
  <joint name="L6_Joint" type="revolute">
    <origin xyz="0 0.028 -0.0435" rpy="0 0 0" />
    <parent link="L5_Link" />
    <child link="L6_Link" />
    <axis xyz="0 -1 0" />
    <limit lower="-1.57" upper="1.57" effort="14" velocity="27.21" />
  </joint>

  <link name="L7_Link">
    <inertial>
      <origin xyz="-0.026398 -6.6336E-15 -0.025801" rpy="0 0 0" />
      <mass value="0.10175" />
      <inertia
        ixx="4.5036E-05" ixy="-4.7046E-12" ixz="2.2349E-07"
        iyy="3.8663E-05" iyz="-1.9234E-20"
        izz="3.0632E-05" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/L7_Link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.75294 0.75294 0.75294 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/L7_Link.STL" />
      </geometry>
    </collision>
  </link>
  <joint name="L7_Joint" type="revolute">
    <origin xyz="0.028 -0.028 -0.075" rpy="0 0 0" />
    <parent link="L6_Link" />
    <child link="L7_Link" />
    <axis xyz="-1 0 0" />
    <limit lower="-1.57" upper="1.57" effort="14" velocity="27.21" />
  </joint>

</robot>
