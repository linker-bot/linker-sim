# Safety net: catches an accidental IsaacLab clone at the repo root.
# The documented location is outside the repo (see docs/installation.md).
IsaacLab/

# Python bytecode and caches.
__pycache__/
*.py[cod]
*.pyo

# Virtual environments and local Python tooling.
.venv/
venv/
.python-version
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Build and packaging artifacts.
build/
dist/
*.egg-info/

# Logs and runtime leftovers.
*.log
*LOG.TXT

# Editor/OS files.
.idea/
.vscode/
.DS_Store
.cursor/
.claude/
assets/usd_generated/
*.usd
*.usda
*.usdc

# Data
outputs/
