  <!-- Scene: world -> table -> arm. Translation in meters, rotation in rpy radians. -->
  <link name="world"/>
  <link name="workstation_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="../workstation.STL"/>
      </geometry>
      <material name="workstation_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="../workstation.STL"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="50.0"/>
      <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
    </inertial>
  </link>
  <joint name="world_to_workstation" type="fixed">
    <parent link="world"/>
    <child link="workstation_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
  <joint name="workstation_to_arm_base" type="fixed">
