<?xml version="1.0" encoding="UTF-8"?>
<robot name="workstation">
  <!--
    Canonical table frame.
    Tune visual/collision origin here once, then keep scene placement simple.
  -->
  <link name="workstation_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="workstation.STL"/>
      </geometry>
      <material name="workstation_gray">
        <color rgba="0.6 0.6 0.6 1.0"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="workstation.STL"/>
      </geometry>
    </collision>

    <!-- Simple placeholder inertial properties. -->
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="50.0"/>
      <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
    </inertial>
  </link>

</robot>
