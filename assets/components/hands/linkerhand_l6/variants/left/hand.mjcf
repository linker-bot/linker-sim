<mujoco model="linkerhand_l6_left">
  <compiler meshdir="meshes" discardvisual="false" autolimits="true" angle="radian" eulerseq="XYZ"/>
  <option/>

  <default>
    <default class="hand_linkerhand_l6_visual">
      <geom type="mesh" contype="0" conaffinity="0" group="1"/>
    </default>
    <default class="hand_linkerhand_l6_collision">
      <geom type="mesh" contype="1" conaffinity="1" group="3"/>
    </default>
    <default class="hand_linkerhand_l6_joint">
      <joint armature="3.4707e-08" damping="5.0" frictionloss="0.5"/>
    </default>
  </default>

  <asset>
    <mesh name="hand_base"             file="hand_base_link.STL"/>
    <mesh name="thumb_metacarpals_base1" file="thumb_metacarpals_base1.STL"/>
    <mesh name="thumb_metacarpals"     file="thumb_metacarpals.STL"/>
    <mesh name="thumb_distal"          file="thumb_distal.STL"/>
    <mesh name="index_proximal"        file="index_proximal.STL"/>
    <mesh name="index_distal"          file="index_distal.STL"/>
    <mesh name="middle_proximal"       file="middle_proximal.STL"/>
    <mesh name="middle_distal"         file="middle_distal.STL"/>
    <mesh name="ring_proximal"         file="ring_proximal.STL"/>
    <mesh name="ring_distal"           file="ring_distal.STL"/>
    <mesh name="pinky_proximal"        file="pinky_proximal.STL"/>
    <mesh name="pinky_distal"          file="pinky_distal.STL"/>
  </asset>

  <worldbody>
    <body name="lh_hand_base_link" pos="0 0 0">
      <inertial pos="0.00199 -0.00091 0.058381" mass="0.4185"
                fullinertia="0.0004998 0.0003567 0.0002301 0.000012853 -0.000008317 0.000010354"/>
      <geom class="hand_linkerhand_l6_visual" mesh="hand_base"/>
      <geom class="hand_linkerhand_l6_collision" mesh="hand_base"/>
      <site name="wrist_mount" pos="0 0 0"/>

      <body name="lh_thumb_metacarpals_base1" pos="0.0078133 -0.029898 0.026692" euler="-0.034907 0 0">
        <inertial pos="0.0018663 -0.0066406 0.001533" mass="0.01"
                  fullinertia="3.3724E-07 2.9457E-07 4.903E-07 1.11E-07 -3.6039E-08 5.7181E-08"/>
        <joint name="lh_thumb_cmc_roll" class="hand_linkerhand_l6_joint" type="hinge" axis="0 0 1"
               range="-0.087266 1.256637"/>
        <geom class="hand_linkerhand_l6_visual" mesh="thumb_metacarpals_base1"/>
        <geom class="hand_linkerhand_l6_collision" mesh="thumb_metacarpals_base1"/>

        <body name="lh_thumb_metacarpals" pos="0.0057298 -0.01332 0.0027456" euler="1.1083 0 0.40143">
          <inertial pos="0.00769270907060086 0.0859662184722988 0.0235283086675235" mass="0.065"
                    fullinertia="8.407E-06 8.3899E-06 2.0091E-06 -1.1338E-09 1.1136E-08 3.1171E-07"/>
          <joint name="lh_thumb_cmc_pitch" class="hand_linkerhand_l6_joint" type="hinge" axis="-1 0 0"
                 range="0 0.837758"/>
          <geom class="hand_linkerhand_l6_visual" mesh="thumb_metacarpals"/>
          <geom class="hand_linkerhand_l6_collision" mesh="thumb_metacarpals"/>

          <body name="lh_thumb_distal" pos="0 0.0061 0.0827">
            <inertial pos="0.00769270907081708 0.0798662184721594 -0.0591716913325555" mass="0.018"
                      fullinertia="1.5546E-06 1.7108E-06 9.1709E-07 2.4423E-09 2.8147E-09 -7.2756E-08"/>
            <joint name="lh_thumb_dip" class="hand_linkerhand_l6_joint" type="hinge" axis="-1 0 0"
                   range="0 0.963287"/>
            <geom class="hand_linkerhand_l6_visual" mesh="thumb_distal"/>
            <geom class="hand_linkerhand_l6_collision" mesh="thumb_distal"/>

            <body name="lh_thumb_tip" pos="0 0.0035 0.026" euler="0 0 1.5708">
              <inertial pos="0 0 0" mass="1e-06" fullinertia="1e-09 1e-09 1e-09 0 0 0"/>
            </body>
          </body>
        </body>
      </body>

      <body name="lh_index_proximal" pos="-0.00066821 -0.028967 0.11722">
        <inertial pos="0.001776 -0.00011 0.012556" mass="0.008553"
                  fullinertia="0.000000797543 0.000000800499 0.000000357001 -0.000000001275 0.000000138601 0.000000000939"/>
        <joint name="lh_index_mcp_pitch" class="hand_linkerhand_l6_joint" type="hinge" axis="0 1 0"
               range="0 1.134464"/>
        <geom class="hand_linkerhand_l6_visual" mesh="index_proximal"/>
        <geom class="hand_linkerhand_l6_collision" mesh="index_proximal"/>

        <body name="lh_index_distal" pos="0.00093749 0 0.028002">
          <inertial pos="0.0134 0.002262 0.016992" mass="0.018408"
                    fullinertia="0.000002488712 0.000003723754 0.000001813582 0.000000008249 -0.000001523059 0.000000014019"/>
          <joint name="lh_index_dip" class="hand_linkerhand_l6_joint" type="hinge" axis="0 1 0"
                 range="0 1.277039"/>
          <geom class="hand_linkerhand_l6_visual" mesh="index_distal"/>
          <geom class="hand_linkerhand_l6_collision" mesh="index_distal"/>

          <body name="lh_index_tip" pos="0.0341 0 0.034">
            <inertial pos="0 0 0" mass="1e-06" fullinertia="1e-09 1e-09 1e-09 0 0 0"/>
          </body>
        </body>
      </body>

      <body name="lh_middle_proximal" pos="-0.00066821 -0.0089013 0.12322">
        <inertial pos="0.001776 -0.00011 0.012556" mass="0.008553"
                  fullinertia="0.000000797543 0.000000800499 0.000000357001 -0.000000001275 0.000000138601 0.000000000939"/>
        <joint name="lh_middle_mcp_pitch" class="hand_linkerhand_l6_joint" type="hinge" axis="0 1 0"
               range="0 1.134464"/>
        <geom class="hand_linkerhand_l6_visual" mesh="middle_proximal"/>
        <geom class="hand_linkerhand_l6_collision" mesh="middle_proximal"/>

        <body name="lh_middle_distal" pos="0.00093749 0 0.028002">
          <inertial pos="0.0134 0.002262 0.016992" mass="0.018408"
                    fullinertia="0.000002488712 0.000003723754 0.000001813582 0.000000008249 -0.000001523059 0.000000014019"/>
          <joint name="lh_middle_dip" class="hand_linkerhand_l6_joint" type="hinge" axis="0 1 0"
                 range="0 1.277039"/>
          <geom class="hand_linkerhand_l6_visual" mesh="middle_distal"/>
          <geom class="hand_linkerhand_l6_collision" mesh="middle_distal"/>

          <body name="lh_middle_tip" pos="0.0341 0 0.034">
            <inertial pos="0 0 0" mass="1e-06" fullinertia="1e-09 1e-09 1e-09 0 0 0"/>
          </body>
        </body>
      </body>

      <body name="lh_ring_proximal" pos="-0.00067368 0.010717 0.11822">
        <inertial pos="0.001776 -0.00011 0.012556" mass="0.008553"
                  fullinertia="0.000000797543 0.000000800499 0.000000357001 -0.000000001275 0.000000138601 0.000000000939"/>
        <joint name="lh_ring_mcp_pitch" class="hand_linkerhand_l6_joint" type="hinge" axis="0 1 0"
               range="0 1.134464"/>
        <geom class="hand_linkerhand_l6_visual" mesh="ring_proximal"/>
        <geom class="hand_linkerhand_l6_collision" mesh="ring_proximal"/>

        <body name="lh_ring_distal" pos="0.00093749 0 0.028002">
          <inertial pos="0.0134 0.002262 0.016992" mass="0.018408"
                    fullinertia="0.000002488712 0.000003723754 0.000001813582 0.000000008249 -0.000001523059 0.000000014019"/>
          <joint name="lh_ring_dip" class="hand_linkerhand_l6_joint" type="hinge" axis="0 1 0"
                 range="0 1.277039"/>
          <geom class="hand_linkerhand_l6_visual" mesh="ring_distal"/>
          <geom class="hand_linkerhand_l6_collision" mesh="ring_distal"/>

          <body name="lh_ring_tip" pos="0.0341 0 0.034">
            <inertial pos="0 0 0" mass="1e-06" fullinertia="1e-09 1e-09 1e-09 0 0 0"/>
          </body>
        </body>
      </body>

      <body name="lh_pinky_proximal" pos="-0.00067852 0.029814 0.11424">
        <inertial pos="0.001776 -0.00011 0.012556" mass="0.008553"
                  fullinertia="0.000000797543 0.000000800499 0.000000357001 -0.000000001275 0.000000138601 0.000000000939"/>
        <joint name="lh_pinky_mcp_pitch" class="hand_linkerhand_l6_joint" type="hinge" axis="0 1 0"
               range="0 1.134464"/>
        <geom class="hand_linkerhand_l6_visual" mesh="pinky_proximal"/>
        <geom class="hand_linkerhand_l6_collision" mesh="pinky_proximal"/>

        <body name="lh_pinky_distal" pos="0.00093749 0 0.028002">
          <inertial pos="0.0134 0.002262 0.016992" mass="0.018408"
                    fullinertia="0.000002488712 0.000003723754 0.000001813582 0.000000008249 -0.000001523059 0.000000014019"/>
          <joint name="lh_pinky_dip" class="hand_linkerhand_l6_joint" type="hinge" axis="0 1 0"
                 range="0 1.277039"/>
          <geom class="hand_linkerhand_l6_visual" mesh="pinky_distal"/>
          <geom class="hand_linkerhand_l6_collision" mesh="pinky_distal"/>

          <body name="lh_pinky_tip" pos="0.0341 0 0.034">
            <inertial pos="0 0 0" mass="1e-06" fullinertia="1e-09 1e-09 1e-09 0 0 0"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <position name="lh_thumb_cmc_roll_act"    joint="lh_thumb_cmc_roll"    kp="20" kv="2" ctrlrange="-0.087266 1.256637"/>
    <position name="lh_thumb_cmc_pitch_act"   joint="lh_thumb_cmc_pitch"   kp="20" kv="2" ctrlrange="0 0.837758"/>
    <position name="lh_index_mcp_pitch_act"   joint="lh_index_mcp_pitch"   kp="20" kv="2" ctrlrange="0 1.134464"/>
    <position name="lh_middle_mcp_pitch_act"  joint="lh_middle_mcp_pitch"  kp="20" kv="2" ctrlrange="0 1.134464"/>
    <position name="lh_ring_mcp_pitch_act"    joint="lh_ring_mcp_pitch"    kp="20" kv="2" ctrlrange="0 1.134464"/>
    <position name="lh_pinky_mcp_pitch_act"   joint="lh_pinky_mcp_pitch"   kp="20" kv="2" ctrlrange="0 1.134464"/>
  </actuator>

  <equality>
    <joint name="lh_couple_index"  joint1="lh_index_dip"  joint2="lh_index_mcp_pitch"  polycoef="0 1.125676 0 0 0"/>
    <joint name="lh_couple_middle" joint1="lh_middle_dip" joint2="lh_middle_mcp_pitch" polycoef="0 1.125676 0 0 0"/>
    <joint name="lh_couple_ring"   joint1="lh_ring_dip"   joint2="lh_ring_mcp_pitch"   polycoef="0 1.125676 0 0 0"/>
    <joint name="lh_couple_pinky"  joint1="lh_pinky_dip"  joint2="lh_pinky_mcp_pitch"  polycoef="0 1.125676 0 0 0"/>
    <joint name="lh_couple_thumb"  joint1="lh_thumb_dip"  joint2="lh_thumb_cmc_pitch"  polycoef="0 1.226495 0 0 0"/>
  </equality>

  <contact>
    <exclude body1="lh_hand_base_link"          body2="lh_thumb_metacarpals_base1"/>
    <exclude body1="lh_thumb_metacarpals_base1" body2="lh_thumb_metacarpals"/>
    <exclude body1="lh_thumb_metacarpals"       body2="lh_thumb_distal"/>
    <exclude body1="lh_hand_base_link"          body2="lh_index_proximal"/>
    <exclude body1="lh_index_proximal"          body2="lh_index_distal"/>
    <exclude body1="lh_hand_base_link"          body2="lh_middle_proximal"/>
    <exclude body1="lh_middle_proximal"         body2="lh_middle_distal"/>
    <exclude body1="lh_hand_base_link"          body2="lh_ring_proximal"/>
    <exclude body1="lh_ring_proximal"           body2="lh_ring_distal"/>
    <exclude body1="lh_hand_base_link"          body2="lh_pinky_proximal"/>
    <exclude body1="lh_pinky_proximal"          body2="lh_pinky_distal"/>
  </contact>
</mujoco>
