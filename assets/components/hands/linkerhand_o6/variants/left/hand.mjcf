        </body>
      </body>

      <body name="lh_index_proximal" pos="0.0024758 -0.02419 0.098779" euler="0.05236 0 0">
        <inertial pos="-0.00208656556336452 2.53838713251686E-06 0.0172734941980264" mass="0.00253174651934627"
                  fullinertia="2.65988714157799E-07 2.72914069166233E-07 8.56017305636748E-08 -1.67174578825824E-11 -4.31047725546034E-08 1.8756709532167E-10"/>
        <joint name="lh_index_mcp_pitch" class="hand_linkerhand_o6_joint" type="hinge" axis="0 1 0" range="0 1.60"/>
        <geom class="hand_linkerhand_o6_visual" mesh="index_proximal"/>
