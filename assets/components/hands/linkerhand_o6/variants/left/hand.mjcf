                    fullinertia="1.10292537368909E-06 1.76757772551884E-06 9.36347792411098E-07 -5.99642232777877E-10 -1.14233573940545E-07 -4.03963570823777E-10"/>
          <joint name="lh_thumb_cmc_pitch" class="hand_linkerhand_o6_joint" type="hinge" axis="0 1 0" range="0 0.58"/>
