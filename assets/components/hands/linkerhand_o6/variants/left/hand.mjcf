                  fullinertia="2.65989756076584E-07 2.7291510093393E-07 8.56031522765909E-08 -1.74912952703656E-11 -4.31043325594253E-08 1.87158326740895E-10"/>
        <joint name="lh_ring_mcp_pitch" class="hand_linkerhand_o6_joint" type="hinge" axis="0 1 0" range="0 1.60"/>
