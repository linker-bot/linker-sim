                      fullinertia="1.3057487813702E-06 1.2248908905341E-06 2.77271910592615E-07 -1.19781508112714E-11 -7.19551697268541E-08 4.55347974652679E-12"/>
            <joint name="lh_thumb_ip" class="hand_linkerhand_o6_joint" type="hinge" axis="0 1 0" range="0 1.08"/>
            <geom class="hand_linkerhand_o6_visual" mesh="thumb_distal"/>
