                    fullinertia="3.22347106085043E-07 3.65328133721509E-07 1.24287996386442E-07 1.3801788663582E-11 1.14352857317951E-07 -2.11505011705634E-10"/>
          <joint name="lh_index_dip" class="hand_linkerhand_o6_joint" type="hinge" axis="0 1 0" range="0 1.43"/>
