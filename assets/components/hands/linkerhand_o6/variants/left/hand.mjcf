<mujoco model="linkerhand_o6_left">
  <compiler meshdir="meshes" discardvisual="false" autolimits="true" angle="radian" eulerseq="XYZ"/>
  <option/>

  <default>
    <default class="hand_linkerhand_o6_visual">
      <geom type="mesh" contype="0" conaffinity="0" group="1"/>
    </default>
    <default class="hand_linkerhand_o6_collision">
      <geom type="mesh" contype="1" conaffinity="1" group="3"/>
    </default>
    <default class="hand_linkerhand_o6_joint">
      <joint armature="3.4707e-08" damping="4.0" frictionloss="0.5"/>
    </default>
  </default>

  <asset>
    <mesh name="hand_base"               file="hand_base_link.STL"/>
    <mesh name="thumb_metacarpals_base2" file="thumb_metacarpals_base2.STL"/>
    <mesh name="thumb_metacarpals"       file="thumb_metacarpals.STL"/>
    <mesh name="thumb_distal"            file="thumb_distal.STL"/>
    <mesh name="index_proximal"          file="index_proximal.STL"/>
    <mesh name="index_distal"            file="index_distal.STL"/>
    <mesh name="middle_proximal"         file="middle_proximal.STL"/>
    <mesh name="middle_distal"           file="middle_distal.STL"/>
    <mesh name="ring_proximal"           file="ring_proximal.STL"/>
    <mesh name="ring_distal"             file="ring_distal.STL"/>
    <mesh name="pinky_proximal"          file="pinky_proximal.STL"/>
    <mesh name="pinky_distal"            file="pinky_distal.STL"/>
  </asset>

  <worldbody>
    <body name="lh_hand_base_link" pos="0 0 0">
      <inertial pos="-0.00157788568070457 -0.00034876725935859 0.0538452219801211" mass="0.0672935238166485"
                fullinertia="5.22525212160954E-05 3.33522349207724E-05 2.28469461105385E-05 3.06955729584715E-07 -3.90341166950521E-07 -7.76680063574627E-07"/>
      <geom class="hand_linkerhand_o6_visual" mesh="hand_base"/>
      <geom class="hand_linkerhand_o6_collision" mesh="hand_base"/>
      <site name="wrist_mount" pos="0 0 0"/>

      <body name="lh_thumb_metacarpals_base2" pos="0.011508 -0.022975 0.032794">
        <inertial pos="0.00162800681276937 -0.0027668017246415 -0.00184234438641236" mass="0.00138588296544333"
                  fullinertia="5.26292160685909E-08 4.82620491570326E-08 2.88550286112821E-08 -3.92888681640568E-09 -2.43767371295222E-09 3.71869784206147E-09"/>
        <joint name="lh_thumb_cmc_yaw" class="hand_linkerhand_o6_joint" type="hinge" axis="0 0 1" range="0 1.3"/>
