    </body>
  </worldbody>

  <actuator>
    <position name="lh_thumb_cmc_yaw_act"    joint="lh_thumb_cmc_yaw"    kp="200" kv="0" ctrlrange="0 1.3"/>
    <position name="lh_thumb_cmc_pitch_act"  joint="lh_thumb_cmc_pitch"  kp="200" kv="0" ctrlrange="0 0.58"/>
    <position name="lh_index_mcp_pitch_act"  joint="lh_index_mcp_pitch"  kp="200" kv="0" ctrlrange="0 1.60"/>
    <position name="lh_middle_mcp_pitch_act" joint="lh_middle_mcp_pitch" kp="200" kv="0" ctrlrange="0 1.60"/>
    <position name="lh_ring_mcp_pitch_act"   joint="lh_ring_mcp_pitch"   kp="200" kv="0" ctrlrange="0 1.60"/>
    <position name="lh_pinky_mcp_pitch_act"  joint="lh_pinky_mcp_pitch"  kp="200" kv="0" ctrlrange="0 1.60"/>
  </actuator>

  <equality>
    <joint name="lh_couple_thumb"  joint1="lh_thumb_ip"     joint2="lh_thumb_cmc_pitch"  polycoef="0 2.29 0 0 0"/>
    <joint name="lh_couple_index"  joint1="lh_index_dip"    joint2="lh_index_mcp_pitch"  polycoef="0 0.89 0 0 0"/>
    <joint name="lh_couple_middle" joint1="lh_middle_dip"   joint2="lh_middle_mcp_pitch" polycoef="0 0.89 0 0 0"/>
    <joint name="lh_couple_ring"   joint1="lh_ring_dip"     joint2="lh_ring_mcp_pitch"   polycoef="0 0.89 0 0 0"/>
    <joint name="lh_couple_pinky"  joint1="lh_pinky_dip"    joint2="lh_pinky_mcp_pitch"  polycoef="0 0.89 0 0 0"/>
  </equality>

  <contact>
    <exclude body1="lh_hand_base_link"          body2="lh_thumb_metacarpals_base2"/>
    <exclude body1="lh_thumb_metacarpals_base2" body2="lh_thumb_metacarpals"/>
    <exclude body1="lh_thumb_metacarpals"       body2="lh_thumb_distal"/>
    <exclude body1="lh_hand_base_link"          body2="lh_index_proximal"/>
    <exclude body1="lh_index_proximal"          body2="lh_index_distal"/>
    <exclude body1="lh_hand_base_link"          body2="lh_middle_proximal"/>
    <exclude body1="lh_middle_proximal"         body2="lh_middle_distal"/>
    <exclude body1="lh_hand_base_link"          body2="lh_ring_proximal"/>
    <exclude body1="lh_ring_proximal"           body2="lh_ring_distal"/>
    <exclude body1="lh_hand_base_link"          body2="lh_pinky_proximal"/>
    <exclude body1="lh_pinky_proximal"          body2="lh_pinky_distal"/>
  </contact>
</mujoco>
