                  fullinertia="2.65989021304483E-07 2.72914402745606E-07 8.5602213431865E-08 -1.69816046635662E-11 -4.31046683215273E-08 1.87484652324395E-10"/>
        <joint name="lh_middle_mcp_pitch" class="hand_linkerhand_o6_joint" type="hinge" axis="0 1 0" range="0 1.60"/>
