                  fullinertia="5.26294625624223E-08 4.82623724532942E-08 2.88555522060562E-08 -3.9288013799604E-09 2.43766268199571E-09 3.71867754115443E-09"/>
        <joint name="rh_thumb_cmc_yaw" class="hand_linkerhand_o6_joint" type="hinge" axis="0 0 -1" range="0 1.36"/>
