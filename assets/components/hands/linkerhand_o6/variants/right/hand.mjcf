                    fullinertia="1.10292488693766E-06 1.76757658485787E-06 9.36348143657406E-07 -6.14241939151719E-10 1.14233108676795E-07 -4.24576599367025E-10"/>
          <joint name="rh_thumb_cmc_pitch" class="hand_linkerhand_o6_joint" type="hinge" axis="0 1 0" range="0 0.58"/>
