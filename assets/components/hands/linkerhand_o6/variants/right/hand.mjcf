                fullinertia="5.22359941041901E-05 3.33473043513648E-05 2.28342677422006E-05 3.0391535852764E-07 3.88322215371643E-07 -7.77555280794861E-07"/>
      <geom class="hand_linkerhand_o6_visual" mesh="hand_base"/>
      <geom class="hand_linkerhand_o6_collision" mesh="hand_base"/>
      <site name="wrist_mount" pos="0 0 0"/>

      <body name="rh_thumb_metacarpals_base2" pos="0.011508 0.022975 0.032794">
