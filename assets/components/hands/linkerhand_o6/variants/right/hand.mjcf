    </body>
  </worldbody>

  <actuator>
    <position name="rh_thumb_cmc_yaw_act"    joint="rh_thumb_cmc_yaw"    kp="20" kv="2" ctrlrange="0 1.36"/>
    <position name="rh_thumb_cmc_pitch_act"  joint="rh_thumb_cmc_pitch"  kp="20" kv="2" ctrlrange="0 0.58"/>
    <position name="rh_index_mcp_pitch_act"  joint="rh_index_mcp_pitch"  kp="20" kv="2" ctrlrange="0 1.60"/>
    <position name="rh_middle_mcp_pitch_act" joint="rh_middle_mcp_pitch" kp="20" kv="2" ctrlrange="0 1.60"/>
    <position name="rh_ring_mcp_pitch_act"   joint="rh_ring_mcp_pitch"   kp="20" kv="2" ctrlrange="0 1.60"/>
    <position name="rh_pinky_mcp_pitch_act"  joint="rh_pinky_mcp_pitch"  kp="20" kv="2" ctrlrange="0 1.60"/>
  </actuator>

  <equality>
    <joint name="rh_couple_thumb"  joint1="rh_thumb_ip"     joint2="rh_thumb_cmc_pitch"  polycoef="0 1.86 0 0 0"/>
    <joint name="rh_couple_index"  joint1="rh_index_dip"    joint2="rh_index_mcp_pitch"  polycoef="0 0.89 0 0 0"/>
    <joint name="rh_couple_middle" joint1="rh_middle_dip"   joint2="rh_middle_mcp_pitch" polycoef="0 0.89 0 0 0"/>
    <joint name="rh_couple_ring"   joint1="rh_ring_dip"     joint2="rh_ring_mcp_pitch"   polycoef="0 0.89 0 0 0"/>
    <joint name="rh_couple_pinky"  joint1="rh_pinky_dip"    joint2="rh_pinky_mcp_pitch"  polycoef="0 0.89 0 0 0"/>
  </equality>

  <contact>
    <exclude body1="rh_hand_base_link"          body2="rh_thumb_metacarpals_base2"/>
    <exclude body1="rh_thumb_metacarpals_base2" body2="rh_thumb_metacarpals"/>
    <exclude body1="rh_thumb_metacarpals"       body2="rh_thumb_distal"/>
    <exclude body1="rh_hand_base_link"          body2="rh_index_proximal"/>
    <exclude body1="rh_index_proximal"          body2="rh_index_distal"/>
    <exclude body1="rh_hand_base_link"          body2="rh_middle_proximal"/>
    <exclude body1="rh_middle_proximal"         body2="rh_middle_distal"/>
    <exclude body1="rh_hand_base_link"          body2="rh_ring_proximal"/>
    <exclude body1="rh_ring_proximal"           body2="rh_ring_distal"/>
    <exclude body1="rh_hand_base_link"          body2="rh_pinky_proximal"/>
    <exclude body1="rh_pinky_proximal"          body2="rh_pinky_distal"/>
  </contact>
</mujoco>
