<!-- Source: /home/zhy/codes/A7_Lite_URDF/urdf/LZARMzongzhuang.urdf (left arm chain).
     Rerooted at a zero-mass virtual link L_arm_root so the recipe's fixed
     mount joint can live above the first revolute L1_Joint. The source's
     joint l2 origin (0.0062932, 0.1505, -0.022706) was absorbed into the
     a7_lite_torso arm_left_mount pad. Source link/joint names l2..l8 are
     renamed L1..L7. Effort/velocity limits backfilled (source had zeros);
     position ranges and inertials copied verbatim. -->
<robot name="a7_lite_left">

  <link name="L_arm_root" />

  <link name="L1_Link">
    <inertial>
      <origin xyz="0.0045974 0.067978 0.00066635" rpy="0 0 0" />
      <mass value="1.1899" />
      <inertia
        ixx="0.0016082" ixy="3.5266E-06" ixz="2.0532E-07"
        iyy="0.00086283" iyz="6.5642E-06"
        izz="0.00092662" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/L1_Link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.75294 0.75294 0.75294 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/L1_Link.STL" />
      </geometry>
    </collision>
  </link>
  <joint name="L1_Joint" type="revolute">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="L_arm_root" />
    <child link="L1_Link" />
    <axis xyz="0 1 0" />
    <limit lower="-3.752" upper="2.181" effort="80" velocity="10.47" />
  </joint>

