<?xml version="1.0" encoding="utf-8"?>
<!-- Joint kinematics (axes, limits, joint origins, effort/velocity)
     come from the vendor's per-side a7_lite_right URDF — the URDF the
     real robot/recorder uses. The previously committed component
     was derived from the combined LZARMzongzhuang.urdf, which had
     different sign conventions on R1/R2/R4 (axes flipped, limits
     negated/swapped) plus 12 mm errors on R3/R4 origin Z. Replay was
     getting clamped because of those.

     Inertials and mount-pad offsets (in a7_lite_torso) keep the
     LZARMzongzhuang values: the per-side URDFs assume a different
     base_link STL than the one our torso ships, so the truth's
     (0, -0.1435, 0) shoulder offset doesn't apply here.

     This component re-roots at a zero-mass virtual link R_arm_root so
     the recipe's fixed mount joint can live above the first revolute
     R1_Joint. -->
<robot name="a7_lite_right">

  <link name="R_arm_root" />

  <link name="R1_Link">
    <inertial>
      <origin xyz="0.004598 -0.067915 0.00072736" rpy="0 0 0" />
      <mass value="1.1899" />
      <inertia
        ixx="0.0016082" ixy="-3.3435E-06" ixz="3.9187E-07"
        iyy="0.00086157" iyz="-6.5828E-06"
        izz="0.00092788" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/R1_Link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.75294 0.75294 0.75294 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/R1_Link.STL" />
      </geometry>
    </collision>
  </link>
  <joint name="R1_Joint" type="revolute">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="R_arm_root" />
    <child link="R1_Link" />
    <axis xyz="0 1 0" />
    <limit lower="-3.75" upper="2.18" effort="60" velocity="18.84" />
  </joint>

  <link name="R2_Link">
    <inertial>
      <origin xyz="-0.031363 2.7784E-05 -0.099445" rpy="0 0 0" />
      <mass value="1.0663" />
      <inertia
        ixx="0.0014523" ixy="-8.9962E-07" ixz="-1.031E-06"
        iyy="0.0012484" iyz="1.1436E-05"
        izz="0.0010754" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/R2_Link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.75294 0.75294 0.75294 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/R2_Link.STL" />
      </geometry>
    </collision>
  </link>
  <joint name="R2_Joint" type="revolute">
    <origin xyz="0.03125 -0.0715 0" rpy="0 0 0" />
    <parent link="R1_Link" />
    <child link="R2_Link" />
    <axis xyz="-1 0 0" />
    <limit lower="-0.19" upper="3.33" effort="60" velocity="18.84" />
  </joint>

  <link name="R3_Link">
    <inertial>
      <origin xyz="-2.2895E-05 -0.00123 -0.077166" rpy="0 0 0" />
      <mass value="1.3517" />
      <inertia
        ixx="0.00080502" ixy="2.8702E-07" ixz="7.1845E-06"
        iyy="0.0010686" iyz="-7.5659E-07"
        izz="0.00067469" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/R3_Link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.75294 0.75294 0.75294 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/R3_Link.STL" />
      </geometry>
    </collision>
  </link>
  <joint name="R3_Joint" type="revolute">
    <origin xyz="-0.03125 0 -0.147" rpy="0 0 0" />
    <parent link="R2_Link" />
    <child link="R3_Link" />
    <axis xyz="0 0 1" />
    <limit lower="-2.26" upper="2.26" effort="17" velocity="37.68" />
  </joint>

  <link name="R4_Link">
    <inertial>
      <origin xyz="1.2714E-05 0.024908 -0.082641" rpy="0 0 0" />
      <mass value="0.69691" />
      <inertia
        ixx="0.00041505" ixy="5.3251E-08" ixz="1.7254E-06"
        iyy="0.00041627" iyz="3.826E-07"
        izz="0.00043007" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/R4_Link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.75294 0.75294 0.75294 1" />
