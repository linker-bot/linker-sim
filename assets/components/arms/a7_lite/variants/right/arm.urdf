<!-- Source: /home/zhy/codes/A7_Lite_URDF/urdf/LZARMzongzhuang.urdf (right arm chain).
     Rerooted at a zero-mass virtual link R_arm_root so the recipe's fixed
     mount joint can live above the first revolute R1_Joint. The source's
     joint r2 origin (0.0062926, -0.1505, -0.022706) was absorbed into the
     a7_lite_torso arm_right_mount pad. Source link/joint names r2..r8 are
     renamed R1..R7. Inertials and joint origins copied verbatim from the
     right-arm chain (NOT mirrored from left — the source isn't perfectly
     symmetric). Effort/velocity limits backfilled (source had zeros). -->
<robot name="a7_lite_right">

  <link name="R_arm_root" />

  <link name="R1_Link">
    <inertial>
      <origin xyz="0.004598 -0.067915 0.00072736" rpy="0 0 0" />
      <mass value="1.1899" />
      <inertia
        ixx="0.0016082" ixy="-3.3435E-06" ixz="3.9187E-07"
        iyy="0.00086157" iyz="-6.5828E-06"
        izz="0.00092788" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/R1_Link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.75294 0.75294 0.75294 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/R1_Link.STL" />
      </geometry>
    </collision>
  </link>
  <joint name="R1_Joint" type="revolute">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="R_arm_root" />
    <child link="R1_Link" />
    <axis xyz="0 -1 0" />
    <limit lower="-2.181" upper="3.752" effort="80" velocity="10.47" />
  </joint>

