    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/R4_Link.STL" />
      </geometry>
    </collision>
  </link>
  <joint name="R4_Joint" type="revolute">
    <origin xyz="0 -0.027 -0.126" rpy="0 0 0" />
    <parent link="R3_Link" />
    <child link="R4_Link" />
    <axis xyz="0 1 0" />
    <limit lower="-1.74" upper="0.78" effort="36" velocity="10.47" />
  </joint>

  <link name="R5_Link">
    <inertial>
      <origin xyz="0.00029153 -0.0027009 -0.035875" rpy="0 0 0" />
      <mass value="0.48527" />
      <inertia
        ixx="0.00016555" ixy="-5.747E-07" ixz="-2.6985E-06"
        iyy="0.00022756" iyz="-9.211E-07"
        izz="0.00015289" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/R5_Link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.75294 0.75294 0.75294 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/R5_Link.STL" />
      </geometry>
    </collision>
  </link>
  <joint name="R5_Joint" type="revolute">
    <origin xyz="0 0.027 -0.136" rpy="0 0 0" />
    <parent link="R4_Link" />
    <child link="R5_Link" />
    <axis xyz="0 0 1" />
    <limit lower="-2.96" upper="2.96" effort="14" velocity="27.21" />
  </joint>

  <link name="R6_Link">
    <inertial>
      <origin xyz="0.0023746 0.027704 -0.063949" rpy="0 0 0" />
      <mass value="0.5193" />
      <inertia
        ixx="0.00031746" ixy="6.3467E-07" ixz="4.1001E-07"
        iyy="0.00024364" iyz="-2.8219E-06"
        izz="0.00015858" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/R6_Link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.75294 0.75294 0.75294 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/R6_Link.STL" />
      </geometry>
    </collision>
  </link>
  <joint name="R6_Joint" type="revolute">
    <origin xyz="0 -0.028 -0.0435" rpy="0 0 0" />
    <parent link="R5_Link" />
    <child link="R6_Link" />
    <axis xyz="0 1 0" />
    <limit lower="-1.57" upper="1.57" effort="14" velocity="27.21" />
  </joint>

  <link name="R7_Link">
    <inertial>
      <origin xyz="-0.026598 3.7248E-14 -0.025801" rpy="0 0 0" />
      <mass value="0.10175" />
      <inertia
        ixx="4.5036E-05" ixy="-4.7046E-12" ixz="2.2349E-07"
        iyy="3.8663E-05" iyz="-1.5968E-20"
        izz="3.0632E-05" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/R7_Link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.75294 0.75294 0.75294 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/R7_Link.STL" />
      </geometry>
    </collision>
  </link>
  <joint name="R7_Joint" type="revolute">
    <origin xyz="0.028 0.028 -0.075" rpy="0 0 0" />
    <parent link="R6_Link" />
    <child link="R7_Link" />
    <axis xyz="-1 0 0" />
    <limit lower="-1.57" upper="1.57" effort="14" velocity="27.21" />
  </joint>

</robot>
